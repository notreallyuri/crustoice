{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "store:default",
    "core:path:default",
    "fs:default",
    "fs:allow-read-file",
    "core:image:allow-from-path",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**/*" }]
    }
  ]
}
